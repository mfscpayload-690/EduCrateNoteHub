# Preferred: full Google service-account JSON (single-line string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternative (recommended on Vercel if JSON secret is hard to manage):
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: Drive root folder that contains your subject folders (defaults to Notes root in code)
# GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id

# Optional: Explicit CORS origins for production
# ALLOWED_ORIGINS=https://educratenoteshub.vercel.app,https://edunotehub.netlify.app

# Optional: max bytes to stream before redirecting to Google Drive preview
# FUNCTION_MAX_RESPONSE_BYTES=4500000
