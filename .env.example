# OpenRouter (server-side only)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_ALLOWLIST=nvidia/nemotron-3-super-120b-a12b:free,nvidia/nemotron-3-super:free
OPENROUTER_TIMEOUT_MS=45000
OPENROUTER_MAX_TOKENS=320

# Firebase Admin + Drive service account (server-side only)
# IMPORTANT (Netlify): choose ONE credential style.
# Recommended: keep FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY and leave GOOGLE_SERVICE_ACCOUNT_JSON unset.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional alternative (single JSON; do not use together with FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY on Netlify)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"service-account@your-project.iam.gserviceaccount.com"}

# Firebase Client (safe to expose to browser, delivered via /api/config/firebase)
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
FIREBASE_APP_ID=1:1234567890:web:abc123def456
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# Comma-separated list of allowed origins (include prod + local development)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000,http://127.0.0.1:3000
